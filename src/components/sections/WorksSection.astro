---
import BaseSection from "./BaseSection.astro"
import PagesMenu from "../menus/PagesMenu.astro"
import GalleryGrid from "../gallery/GalleryGrid.astro"
import GalleryCategoryNav from "../gallery/GalleryCategoryNav.astro"
import data from "../../data/data.json"

interface Props {
  category: {
    id: string;
    title: string;
    images: string[];
  };
}

const { category } = Astro.props;
const worksData = data.find(s => s.id === "works");
const allCategories = worksData?.content ?? [];
const coverImage = worksData?.image ?? "01.jpg";
const menuItems = allCategories.map(item => ({
  label: item.title,
  href: `#${item.id}`
}));
---

<BaseSection id="works">
  <!-- Mobile: sticky category strip + single-category grid (<sm) -->
  <div x-init={`$store.gallery.setCategory(${allCategories.findIndex(c => c.id === category.id)})`} class="sm:hidden flex flex-col w-full h-full min-h-[calc(100svh-2.5rem)]">
    <GalleryCategoryNav categories={allCategories} activeId={category.id} />
    <div class="w-full flex-1">
      <GalleryGrid categories={[category]} />
    </div>
  </div>

  <!-- Desktop (sm+): original dynamic-gallery layout -->
  <div x-data class="hidden sm:flex flex-row w-full h-auto">
    <!-- Left: Cover / Gallery Grid -->
    <div class="relative w-full sm:w-1/2 h-[calc(100svh-2.5rem)] lg:flex-1 lg:h-[calc(100svh-3rem)]">
      <img
        x-show="$store.gallery.activeCategory === null"
        x-transition:leave="transition ease-in duration-200"
        x-transition:leave-start="opacity-100"
        x-transition:leave-end="opacity-0"
        src={`/src/images/${coverImage}`}
        alt={worksData?.title}
        class="w-full h-full object-cover clip-slant-bottom sm:clip-path-none lg:absolute lg:inset-0"
      >

      <div
        x-show="$store.gallery.activeCategory !== null"
        x-cloak
        x-transition:enter="transition ease-out duration-300"
        x-transition:enter-start="opacity-0"
        x-transition:enter-end="opacity-100"
        x-transition:leave="transition ease-in duration-200"
        x-transition:leave-start="opacity-100"
        x-transition:leave-end="opacity-0"
        class="relative w-full h-full overflow-y-auto bg-white lg:absolute lg:inset-0"
      >
        <GalleryGrid categories={allCategories} />
      </div>
    </div>

    <!-- Right: PagesMenu -->
    <div class="w-full sm:w-1/2 lg:flex-1 flex justify-center items-center">
      <div class="wrapper p-8">
        <PagesMenu items={menuItems} />
      </div>
    </div>
  </div>
</BaseSection>

---
import BaseSection from "./BaseSection.astro"
import PagesMenu from "../menus/PagesMenu.astro"
import GalleryGrid from "../gallery/GalleryGrid.astro"
import GalleryCategoryNav from "../gallery/GalleryCategoryNav.astro"
import data from "../../data/data.json"

interface Category {
  id: string;
  title: string;
  images: string[];
}

interface Props {
  category: Category | null;
}

const { category } = Astro.props;
const worksData = data.find(s => s.id === "works");
const allCategories = worksData?.content ?? [];
const coverImage = worksData?.image ?? "01.jpg";
const menuItems = allCategories.map(item => ({
  label: item.title,
  href: `/works/${item.id}/`
}));

const isCover = category === null;
const items = isCover ? [] : category.images.map(src => ({ src, title: category.title }));
---

<BaseSection id="works">
  <!-- Mobile (<sm) and Tablet (sm): cover image on top, PagesMenu below.
       Used ONLY on the cover (/works/). Detail pages render the desktop
       row layout at all breakpoints, so the gallery grid stays usable. -->
  {isCover && (
    <div class="lg:hidden flex flex-col w-full gap-8 sm:gap-20">
      <div class="w-full h-[calc(50svh-1.25rem)] sm:h-[calc(60svh-1.5rem)]">
        <img
          src={`/src/images/${coverImage}`}
          alt={worksData?.title}
          class="w-full h-full object-cover clip-slant-bottom sm:clip-path-none"
        />
      </div>
      <div class="w-full flex justify-center items-center">
        <div class="wrapper p-8">
          <PagesMenu items={menuItems} currentHref={undefined} />
        </div>
      </div>
    </div>
  )}

  {!isCover && (
    <div class="lg:hidden flex flex-col w-full h-full">
      <GalleryCategoryNav categories={allCategories} activeId={category?.id} />
      <div class="w-full flex-1 overflow-y-auto bg-white">
        <GalleryGrid items={items} />
      </div>
    </div>
  )}

  <!-- Desktop (lg+): cover/grid on the left, PagesMenu on the right -->
  <div class="hidden lg:flex flex-row w-full h-auto">
    <!-- Left: Cover / Gallery Grid -->
    <div class="relative w-full lg:flex-1 h-[calc(100svh-3rem)]">
      {isCover ? (
        <img
          src={`/src/images/${coverImage}`}
          alt={worksData?.title}
          class="w-full h-full object-cover clip-slant-bottom sm:clip-path-none lg:absolute lg:inset-0"
        />
      ) : (
        <div class="w-full h-full overflow-y-auto bg-white lg:absolute lg:inset-0">
          <GalleryGrid items={items} />
        </div>
      )}
    </div>

    <!-- Right: PagesMenu -->
    <div class="w-full lg:flex-1 flex justify-center items-center">
      <div class="wrapper p-8">
        <PagesMenu items={menuItems} currentHref={category ? `/works/${category.id}/` : undefined} />
      </div>
    </div>
  </div>
</BaseSection>

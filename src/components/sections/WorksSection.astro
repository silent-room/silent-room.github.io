---
import BaseSection from "./BaseSection.astro"
import PagesMenu from "../menus/PagesMenu.astro"
import GalleryGrid from "../gallery/GalleryGrid.astro"
import GalleryCategoryNav from "../gallery/GalleryCategoryNav.astro"
import data from "../../data/data.json"

interface Category {
  id: string;
  title: string;
  images: string[];
}

interface Props {
  category: Category | null;
}

const { category } = Astro.props;
const worksData = data.find(s => s.id === "works");
const allCategories = worksData?.content ?? [];
const coverImage = worksData?.image ?? "01.jpg";
const menuItems = allCategories.map(item => ({
  label: item.title,
  href: `/works/${item.id}/`
}));

const isCover = category === null;
const items = isCover ? [] : category.images.map(src => ({ src, title: category.title }));
---

<BaseSection id="works">
  <!-- Mobile: sticky category strip + grid (<sm) -->
  <div class="sm:hidden flex flex-col w-full h-full min-h-[calc(100svh-2.5rem)]">
    <GalleryCategoryNav categories={allCategories} activeId={category?.id} />
    <div class="w-full flex-1">
      {isCover ? (
        <img src={`/src/images/${coverImage}`} alt={worksData?.title} class="w-full h-full object-cover" />
      ) : (
        <GalleryGrid items={items} />
      )}
    </div>
  </div>

  <!-- Desktop (sm+): cover/grid on the left, PagesMenu on the right -->
  <div class="hidden sm:flex flex-row w-full h-auto">
    <!-- Left: Cover / Gallery Grid -->
    <div class="relative w-full sm:w-1/2 h-[calc(100svh-2.5rem)] lg:flex-1 lg:h-[calc(100svh-3rem)]">
      {isCover ? (
        <img
          src={`/src/images/${coverImage}`}
          alt={worksData?.title}
          class="w-full h-full object-cover clip-slant-bottom sm:clip-path-none lg:absolute lg:inset-0"
        />
      ) : (
        <div class="w-full h-full overflow-y-auto bg-white lg:absolute lg:inset-0">
          <GalleryGrid items={items} />
        </div>
      )}
    </div>

    <!-- Right: PagesMenu -->
    <div class="w-full sm:w-1/2 lg:flex-1 flex justify-center items-center">
      <div class="wrapper p-8">
        <PagesMenu items={menuItems} mode="navigate" />
      </div>
    </div>
  </div>
</BaseSection>

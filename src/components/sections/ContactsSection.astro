---
import BaseSection from "./BaseSection.astro"

const id = "contacts";
---

<BaseSection {id}>
  <div class="flex flex-col lg:flex-row w-full">
    <!-- Image Side -->
    <div class="w-full h-[calc(50svh-1.25rem)] lg:relative lg:flex-1 lg:h-auto">
      <img
        src="/src/images/Heroes/contacts.jpg"
        alt="Контакты"
        class="w-full h-full object-cover clip-slant-bottom sm:clip-path-none lg:absolute lg:inset-0"
      />
    </div>

    <!-- Content Side -->
    <div class="w-full lg:flex-1 flex justify-center items-center p-8 bg-white text-black min-h-[50svh]">
      <div class="max-w-2xl w-full text-center pt-8">
        <!-- Block 1 -->
        <div class=" border-b-1 border-dashed border-zinc-700 pb-16">
          <p class="text-xl sm:text-2xl font-bold  leading-[200%] tracking-tight">ХОТИТЕ СДЕЛАТЬ ЗАКАЗ?</p>
          <p class="text-xl sm:text-2xl font-bold  leading-[200%] tracking-tight">НУЖНО УТОЧНИТЬ ДЕТАЛИ?</p>
					<p class="text-xl sm:text-2xl font-bold  leading-[200%] tracking-tight">ОСТАЛИСЬ ВОПРОСЫ?</p>

        </div>

        <!-- Block 2 -->
        <div class="pt-16">
          <p class="text-xl sm:text-2xl font-bold">НАПИШИТЕ МНЕ!</p>
        </div>

        <!-- Block 3: Social icons -->
        <div class="flex justify-center gap-16">
          <a href="https://vk.com/" target="_blank" rel="noopener noreferrer" class="py-16 pl-16 pr-0 flex items-center justify-center transition-opacity hover:opacity-70" aria-label="ВКонтакте">
            <img src="/VK_logo_Black_64x64.svg" alt="ВКонтакте" class="w-16 h-16" />
          </a>
          <a href="https://t.me/" target="_blank" rel="noopener noreferrer" class="py-16 pl-0 pr-16 flex items-center justify-center transition-opacity hover:opacity-70" aria-label="Telegram">
            <img src="/TG_Logo.svg" alt="Telegram" class="w-16 h-16" />
          </a>
        </div>
      </div>
    </div>
  </div>
</BaseSection>

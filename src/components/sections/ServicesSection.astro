---
import BaseSection from "./BaseSection.astro"
import PagesMenu from "../menus/PagesMenu.astro"
import data from "../../data/data.json"

const servicesData = data.find(s => s.id === "services");
const sections = servicesData?.content.map(item => ({
  label: item.title,
  href: `#${item.id}`
})) ?? [];
---

<BaseSection id="services">
  <div class="wrapper p-8 flex justify-center items-center w-full">
    <PagesMenu items={sections} />
  </div>
</BaseSection>

---
import BaseSection from "../BaseSection.astro"
import data from "../../../data/data.json"

const servicesData = data.find(s => s.id === "services");
const service = servicesData?.content.find(s => s.id === "retouch");
---

{service && (
  <BaseSection id="service-retouch">
    <div class="wrapper p-8 w-full">
      <h2 class="text-4xl font-bold uppercase mb-8">{service.title}</h2>
      <ul class="space-y-2">
        {service.list.map(item => (
          <li class="text-lg">
            {item.title}
            {item.price && <span> — {item.price} руб./{item.quantity}</span>}
          </li>
        ))}
      </ul>
      {service.note && <p class="mt-4 text-sm text-zinc-500">{service.note}</p>}
    </div>
  </BaseSection>
)}

---
type PagesMenuMode = "switch" | "navigate";

interface Props {
  items: { label: string; href: string }[];
  mode?: PagesMenuMode;
}

const { items, mode = "switch" } = Astro.props;
const isSwitch = mode === "switch";
---

<ul
  x-data
  class="flex flex-col space-y-3"
>
  {items.map((item, index) => (
    <li
      data-id={index}
      {...(isSwitch
        ? { "@click.prevent": `$store.gallery.setCategory(${index})` }
        : {})}
      class="group relative text-3xl md:text-4xl lg:text-5xl text-left font-extrabold md:font-bold uppercase font-features-['smcp'] mb-6 leading-[0.7] cursor-pointer"
    >
      {isSwitch ? (
        <div
          class="absolute inset-y-0 -left-2 -right-2 z-0 transition-all duration-200 -rotate-6 scale-x-125 scale-y-200 group-hover:opacity-100"
          x-cloak
          x-bind:class={`$store.gallery.activeCategory == ${index} ? 'bg-black opacity-100' : 'bg-rose-400 opacity-0'`}
        ></div>
      ) : (
        <div class="absolute inset-y-0 -left-2 -right-2 z-0 transition-all duration-200 -rotate-6 scale-x-125 scale-y-200 group-hover:opacity-100 bg-rose-400 opacity-0"></div>
      )}
      <a
        href={item.href}
        class:list={[
          "relative z-10 block transition-colors duration-200 group-hover:text-olive-100",
          isSwitch ? "" : "text-black-blue",
        ]}
        {...(isSwitch
          ? {
              "x-bind:class": `$store.gallery.activeCategory == ${index} ? 'text-white' : 'text-black-blue'`,
            }
          : {})}
      >
        {item.label}
      </a>
    </li>
  ))}
</ul>

---
import data from "../../data/data.json";

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const path = Astro.url.pathname;
const relativePath = path.startsWith(base) ? path.slice(base.length) || '/' : path;

const menuItems = data.map(section => ({
  id: section.id,
  name: section.title,
  href: section.href ? base + section.href : `#${section.id}`,
  active: section.href ? relativePath.startsWith(section.href) : false,
}));
---

<nav class="sticky top-0 z-50 w-full h-10 md:h-10 lg:h-12 bg-black-blue text-white px-4 lg:pl-24 flex items-center justify-between">
  <!-- Logo/Brand -->
  <div class="text-xl" id="title">
    <a href={base + "/works/"}>{ "{H} Рукавишникова"}</a>
  </div>

  <!-- Desktop Menu -->
  <div id="desktop-menu" class="hidden sm:flex items-center gap-6 xl:gap-24 md:pr-8 xl:pr-24">
    {menuItems.map(item => (
      <a
        href={item.href}
        class={`transition-colors ${item.active ? 'text-zinc-200' : 'text-white hover:text-zinc-300'}`}
      >{item.name}</a>
    ))}
  </div>

  <!-- Mobile Toggle -->
  <button
    type="button"
    id="mobile-menu-toggle"
    aria-label="Toggle Menu"
    aria-controls="mobile-menu"
    aria-expanded="false"
    class="sm:hidden p-2 text-zinc-300 focus:outline-none"
  >
    <svg class="burger-open w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
    </svg>
    <svg class="burger-close w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
    </svg>
  </button>

  <!-- Mobile Menu -->
  <div
    id="mobile-menu"
    data-open="false"
    class="mobile-menu fixed inset-x-0 top-10 bottom-0 bg-olive-50 flex flex-col items-center justify-center gap-6 sm:hidden"
  >
    {menuItems.map(item => (
      <a href={item.href} class={`mobile-menu-link transition-colors text-center py-2 ${item.active ? 'text-rose-400 font-bold' : 'text-zinc-600 hover:text-black'}`}>{item.name}</a>
    ))}
  </div>
</nav>

<style>
  @reference "../../styles/global.css";

  #title > a,
  #desktop-menu > a {
    @apply text-base sm:text-[1rem] md:text-[1.1rem] lg:text-[1.15rem] font-features-['smcp'] tracking-tight uppercase font-extrabold;
  }
  #mobile-menu > a {
    @apply text-3xl md:text-4xl lg:text-5xl font-features-['smcp'] tracking-tight uppercase font-extrabold;
  }

  /* Burger icon switch */
  #mobile-menu-toggle[aria-expanded="false"] .burger-close,
  #mobile-menu-toggle[aria-expanded="true"] .burger-open {
    display: none;
  }

  /* Mobile menu show/hide with transition */
  #mobile-menu {
    opacity: 0;
    transform: translateY(-0.5rem);
    pointer-events: none;
    transition: opacity 200ms ease-out, transform 200ms ease-out;
  }
  #mobile-menu[data-open="true"] {
    opacity: 1;
    transform: translateY(0);
    pointer-events: auto;
  }
</style>

<script>
  function initBurger() {
    const toggle = document.getElementById('mobile-menu-toggle');
    const menu = document.getElementById('mobile-menu');
    if (!toggle || !menu) return;
    if ((toggle as any).__burgerBound) return;
    (toggle as any).__burgerBound = true;
    toggle.addEventListener('click', () => {
      const open = toggle.getAttribute('aria-expanded') === 'true';
      toggle.setAttribute('aria-expanded', String(!open));
      menu.setAttribute('data-open', String(!open));
    });
    document.querySelectorAll('.mobile-menu-link').forEach(a => {
      a.addEventListener('click', () => {
        toggle.setAttribute('aria-expanded', 'false');
        menu.setAttribute('data-open', 'false');
      });
    });
  }
  document.addEventListener('astro:page-load', initBurger);
  initBurger();
</script>

---
interface Item {
  src: string;
  title: string;
}

interface Props {
  items: Item[];
}

const { items } = Astro.props;
---

<div class="w-full h-full overflow-y-auto">
  <div class="grid grid-cols-2 sm:grid-cols-3">
    {items.map(item => (
      <button
        type="button"
        class="gallery-btn aspect-square overflow-hidden cursor-pointer"
        data-src={`/src/images/${item.src}`}
        data-title={item.title}
      >
        <img
          src={`/src/images/${item.src}`}
          alt={item.title}
          class="w-full h-full object-cover transition-opacity duration-300 hover:opacity-80"
        />
      </button>
    ))}
  </div>
</div>

<script>
  import "../../scripts/gallery-lightbox.ts";
</script>

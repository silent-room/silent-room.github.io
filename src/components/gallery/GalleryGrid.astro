---
import { Image, getImage } from "astro:assets"

interface Item {
  src: string;
  title: string;
}

interface Props {
  items: Item[];
}

const { items } = Astro.props;

// Import all images from src/images using glob
const imageModules = import.meta.glob<{ default: ImageMetadata }>("../../images/**/*.{jpg,jpeg,png,webp}", { eager: true });

// Helper to get image module by relative path
function getImageModule(path: string) {
  const key = `../../images/${path}`;
  const mod = imageModules[key];
  if (!mod) {
    console.warn(`Image not found: ${key}`);
    return null;
  }
  return mod.default;
}

// Pre-optimize images for lightbox at build time (avoids /_image runtime endpoint)
type ItemWithImage = { originalSrc: string; imageModule: ImageMetadata; lightboxSrc: string; title: string };
const itemsWithImages: ItemWithImage[] = (await Promise.all(items.map(async item => {
  const imageModule = getImageModule(item.src);
  if (!imageModule) return null;

  const optimized = await getImage({
    src: imageModule,
    width: 1920,
    fit: "inside",
    format: "webp",
  });

  return {
    originalSrc: item.src,
    imageModule,
    lightboxSrc: optimized.src,
    title: item.title,
  };
}))).filter((v): v is ItemWithImage => v !== null);
---

<div class="w-full h-full overflow-y-auto">
  <div class="grid grid-cols-2 sm:grid-cols-3">
    {itemsWithImages.map(item => (
      <button
        type="button"
        class="gallery-btn aspect-square overflow-hidden cursor-pointer"
        data-src={item.lightboxSrc}
        data-title={item.title}
      >
        <Image
          src={item.imageModule}
          alt={item.title}
          class="w-full h-full object-cover transition-opacity duration-300 hover:opacity-80"
        />
      </button>
    ))}
  </div>
</div>

<script>
  import "../../scripts/gallery-lightbox.ts";
</script>

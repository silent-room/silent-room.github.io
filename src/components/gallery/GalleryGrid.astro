---
import { Image } from "astro:assets"

interface Item {
  src: string;
  title: string;
}

interface Props {
  items: Item[];
}

const { items } = Astro.props;

// Import all images from src/images using glob
const imageModules = import.meta.glob<{ default: ImageMetadata }>("../../images/**/*.{jpg,jpeg,png,webp}", { eager: true });

// Helper to get image module by relative path
function getImage(path: string) {
  const key = `../../images/${path}`;
  const mod = imageModules[key];
  if (!mod) {
    console.warn(`Image not found: ${key}`);
    return null;
  }
  return mod.default;
}

const itemsWithImages = items.map(item => ({
  ...item,
  imageModule: getImage(item.src)
})).filter(item => item.imageModule);

// Helper to construct /_image URL for lightbox
function imageSrcToUrl(metadata: ImageMetadata): string {
  const params = new URLSearchParams({
    href: `/src/images/${metadata.src.replace(/^.*src\/images\//, '')}`,
    w: String(metadata.width),
    h: String(metadata.height),
    f: "webp"
  });
  return `/_image?${params.toString()}`;
}
---

<div class="w-full h-full overflow-y-auto">
  <div class="grid grid-cols-2 sm:grid-cols-3">
    {itemsWithImages.map(item => (
      <button
        type="button"
        class="gallery-btn aspect-square overflow-hidden cursor-pointer"
        data-src={imageSrcToUrl(item.imageModule)}
        data-title={item.title}
      >
        <Image
          src={item.imageModule}
          alt={item.title}
          class="w-full h-full object-cover transition-opacity duration-300 hover:opacity-80"
        />
      </button>
    ))}
  </div>
</div>

<script>
  import "../../scripts/gallery-lightbox.ts";
</script>
---
interface Category {
  id: string;
  title: string;
  href: string;
}

interface Props {
  categories: Category[];
  activeId?: string;
}

const { categories, activeId } = Astro.props;
const activeIndex = categories.findIndex(c => c.id === activeId);
const prev = activeIndex > 0 ? categories[activeIndex - 1] : null;
const next = activeIndex >= 0 && activeIndex < categories.length - 1 ? categories[activeIndex + 1] : null;
const active = activeIndex >= 0 ? categories[activeIndex] : null;
---

<nav
  aria-label="Категории работ"
  class="sticky top-10 z-40 bg-black-blue text-white border-t border-white/10"
>
  <ul class="grid grid-cols-3 items-center px-2 sm:px-6 py-3 uppercase font-extrabold font-features-['smcp'] tracking-tight">
    <li class="text-left">
      {prev ? (
        <a
          href={prev.href}
          class="text-xs sm:text-sm opacity-60 hover:opacity-100 transition-opacity"
        >{prev.title}</a>
      ) : <span aria-hidden="true"></span>}
    </li>
    <li class="text-center">
      {active ? (
        <span aria-current="page" class="text-base sm:text-xl">{active.title}</span>
      ) : <span aria-hidden="true"></span>}
    </li>
    <li class="text-right">
      {next ? (
        <a
          href={next.href}
          class="text-xs sm:text-sm opacity-60 hover:opacity-100 transition-opacity"
        >{next.title}</a>
      ) : <span aria-hidden="true"></span>}
    </li>
  </ul>
</nav>

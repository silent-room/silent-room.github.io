---
import BaseLayout from "../../layout/BaseLayout.astro"
import ServiceDetail from "../../components/services/ServiceDetail.astro"
import data from "../../data/data.json"

export async function getStaticPaths() {
  const servicesData = data.find(s => s.id === "services");
  const servicesList = servicesData?.content ?? [];
  const base = import.meta.env.BASE_URL.replace(/\/$/, '');
  return servicesList.map((service, i) => ({
    params: { slug: service.id },
    props: {
      service,
      prev: i > 0 ? { title: servicesList[i-1].title, href: base + servicesList[i-1].href } : null,
      next: i < servicesList.length - 1 ? { title: servicesList[i+1].title, href: base + servicesList[i+1].href } : null,
    },
  })) ?? [];
}

const { service, prev, next } = Astro.props;
---

<BaseLayout title={service.title}>
  <ServiceDetail {service} {prev} {next} />
</BaseLayout>

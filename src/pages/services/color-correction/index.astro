---
import BaseLayout from "../../../layout/BaseLayout.astro"
import data from "../../../data/data.json"

const id = "color-correction";
const servicesData = data.find(s => s.id === "services");
const service = servicesData?.content.find(s => s.id === id);
---

<BaseLayout title={service?.title ?? "Цветокоррекция"}>
  <section class="w-full h-[calc(100svh-3rem)] md:h-[calc(100svh-3.5rem)] lg:h-[calc(100svh-4rem)] flex">
    <div class="flex flex-col lg:flex-row w-full h-full">
      <!-- Image -->
      <div class="w-full h-1/2 lg:flex-1 lg:h-full">
        <img src={`/src/images/${service?.image}`} alt={service?.title} class="w-full h-full object-cover clip-slant-bottom sm:clip-path-none">
      </div>
      <!-- Content -->
      <div class="w-full lg:flex-1 flex justify-center items-center">
        <div class="wrapper p-8">
          <a href="/services/" class="text-sm text-zinc-400 hover:text-zinc-200 transition-colors mb-6 inline-block">← Назад к услугам</a>
          <h2 class="text-4xl font-bold uppercase mb-8">{service?.title}</h2>
          <ul class="space-y-2">
            {service?.list.map(item => (
              <li class="text-lg">
                {item.title}
                {"default_price" in service && service.default_price && <span> — {service.default_price} руб./{service.quantity}</span>}
              </li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

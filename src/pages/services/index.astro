---
import BaseLayout from "../../layout/BaseLayout.astro"
import PagesMenu from "../../components/menus/PagesMenu.astro"
import data from "../../data/data.json"

const sectionData = data.find(s => s.id === "services");
const sections = sectionData?.content.map(item => ({
  label: item.title,
  href: item.href ?? `#${item.id}`
})) ?? [];
---

<BaseLayout title="Услуги">
  <section class="section flex">
    <div class="flex flex-col lg:flex-row-reverse w-full lg:h-auto gap-8 sm:gap-20 lg:gap-0">
      <!-- Image -->
      <div class="w-full h-[calc(50svh-1.25rem)] lg:relative lg:flex-1 lg:h-auto">
        <img src={`/src/images/${sectionData?.image}`} alt={sectionData?.title} class="w-full h-full object-cover clip-slant-bottom sm:clip-path-none lg:absolute lg:inset-0">
      </div>
      <!-- Menu -->
      <div class="w-full lg:flex-1 flex justify-center items-center">
        <div class="wrapper p-8">
          <PagesMenu items={sections} />
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

---
import BaseLayout from "../../layout/BaseLayout.astro"
import PagesMenu from "../../components/menus/PagesMenu.astro"
import data from "../../data/data.json"

const sectionData = data.find(s => s.id === "services");
const sections = sectionData?.content.map(item => ({
  label: item.title,
  href: item.href ?? `#${item.id}`
})) ?? [];
---

<BaseLayout title="Услуги">
  <section class="w-full h-[calc(100svh-3rem)] md:h-[calc(100svh-3.5rem)] lg:h-[calc(100svh-4rem)] flex">
    <div class="flex flex-col lg:flex-row-reverse w-full h-full">
      <!-- Image -->
      <div class="w-full h-1/2 lg:flex-1 lg:h-full">
        <img src={`src/images/${sectionData?.image}`} alt={sectionData?.title} class="w-full h-full object-cover clip-slant-bottom sm:clip-path-none">
      </div>
      <!-- Menu -->
      <div class="w-full lg:flex-1 flex justify-center items-center">
        <div class="wrapper p-8">
          <PagesMenu items={sections} />
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
